+        InputStream stream = Bukkit.class.getClassLoader().getResourceAsStream("META-INF/maven/de.verdox.mccreativelab/mccreativelab-api/pom.properties"); // MCCreativeLab
         Properties properties = new Properties();
 
         if (stream != null) {
