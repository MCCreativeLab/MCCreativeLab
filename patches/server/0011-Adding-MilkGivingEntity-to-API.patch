@@ -106,6 +106,7 @@ public class EntityTypesTest {
             Minecart.class,
             Mob.class,
             Monster.class,
+            org.bukkit.entity.MilkGivingEntity.class, // MCCLab: Add MilkGivingEntity
             NPC.class,
             PiglinAbstract.class,
             Projectile.class,
